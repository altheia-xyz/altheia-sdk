{
  "name": "@altheia-xyz/solana-agent-kit",
  "version": "0.0.1",
  "description": "Altheia adapter for Solana Agent Kit (SendAI) — gate every SAK action with Altheia policy + audit.",
  "license": "Apache-2.0",
  "homepage": "https://altheia.xyz",
  "repository": {
    "type": "git",
    "url": "https://github.com/altheia-xyz/altheia-sdk.git",
    "directory": "packages/solana-agent-kit"
  },
  "keywords": ["solana", "solana-agent-kit", "sak", "sendai", "altheia"],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "solana-agent-kit": ">=2.0.0"
  },
  "dependencies": {
    "@altheia-xyz/sdk": "workspace:*",
    "@altheia-xyz/types": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
