{
  "name": "@altheia-xyz/recover",
  "version": "0.0.1",
  "description": "AI agents you can fire — operator recovery CLI. Withdraws every asset from an Altheia agent's smart-account back to your wallet using only your local keypair. No Altheia backend required.",
  "license": "Apache-2.0",
  "homepage": "https://altheia.xyz",
  "repository": {
    "type": "git",
    "url": "https://github.com/altheia-xyz/altheia-sdk.git",
    "directory": "packages/recover"
  },
  "keywords": ["solana", "altheia", "swig", "recovery", "non-custodial", "cli"],
  "type": "module",
  "bin": {
    "altheia-recover": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "module": "./dist/cli.js",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --target node22 --clean",
    "postbuild": "node -e \"const f='dist/cli.js';const fs=require('fs');fs.writeFileSync(f,'#!/usr/bin/env node\\n'+fs.readFileSync(f,'utf8'));fs.chmodSync(f,0o755)\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.0",
    "@swig-wallet/classic": "^1.9.0",
    "@coral-xyz/anchor": "^0.31.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  }
}
